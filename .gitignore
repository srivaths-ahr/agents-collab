# --- Runtime artifacts the driver generates (not source) ---
.loop/
plan.md
verdict.json
clarifications.md
clarifications_needed.json

# --- Per-run USER content, not part of the tool. Ignored so private tasks /
#     codebase maps never get committed into this public tool repo. ---
task.md
context.md

# --- Python ---
__pycache__/
*.pyc
.venv/
venv/

# --- OS / editor ---
.DS_Store
.idea/
.vscode/
venv.sh

# --- Worked examples are committed on purpose. The bare-name rules above
#     (task.md, context.md, plan.md, verdict.json) would otherwise hide the
#     example inputs and captured run artifacts anywhere in the tree. ---
!examples/**/task.md
!examples/**/context.md
!examples/**/plan.md
!examples/**/verdict.json
# Belt and braces: never commit a bundled tool copy or scratch left in an example.
examples/**/driver.py
examples/**/executors.py
examples/**/AGENTS.md
examples/**/prompts/
